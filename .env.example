###############################################################################
# Docker Compose local configuration template
#
# Create your untracked local environment file:
#
#   cp .env.example .env
#
# Then set POSTGRES_PASSWORD in .env before starting the stack.
###############################################################################


###############################################################################
# Application ports
###############################################################################

# Port on which Spring Boot listens inside the application container.
SERVER_PORT=4000

# Port used to access the application from the local Docker host.
#
# Example:
# APP_HOST_PORT=4000 and SERVER_PORT=4000 makes the application available at:
# http://localhost:4000
APP_HOST_PORT=4000


###############################################################################
# PostgreSQL configuration
###############################################################################

# Database created during first-time PostgreSQL initialisation.
POSTGRES_DB=devtest

# Optional PostgreSQL username override.
#
# When omitted or empty, docker-compose.yml defaults this value to `postgres`
# for both the database container and Spring Boot datasource.
#
# POSTGRES_USER=postgres

# Required: provide a local value only after copying this file to .env.
# Do not commit a real database password.
POSTGRES_PASSWORD=

# Host port used for local PostgreSQL administration through tools such as
# psql, DBeaver or pgAdmin. Access is restricted to the local Docker host.
POSTGRES_HOST_PORT=5432


###############################################################################
# Optional datasource configuration
###############################################################################

# Optional suffix appended to the PostgreSQL JDBC URL.
#
# Examples:
# DB_OPTIONS=?sslmode=disable
# DB_OPTIONS=?sslmode=require
DB_OPTIONS=


###############################################################################
# Optional JVM configuration
###############################################################################

# Optional JVM arguments supplied without rebuilding the image.
#
# Example:
# JAVA_TOOL_OPTIONS=-XX:MaxRAMPercentage=75.0
JAVA_TOOL_OPTIONS=
